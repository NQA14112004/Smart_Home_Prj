# Copy to Pi5/.env and fill in real values. NEVER commit Pi5/.env (gitignored).

# PostgreSQL on the Pi 5 (psycopg connection string).
# After moving the DB to the Pi, this points at localhost.
DATABASE_URL=postgresql://app:CHANGE_ME@127.0.0.1:5432/Smart_Home_db

# Mosquitto credentials for the bridge user (create with mosquitto_passwd).
MQTT_USERNAME=bridge
MQTT_PASSWORD=CHANGE_ME
