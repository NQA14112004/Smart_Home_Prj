# .NET build output
bin/
obj/

# Test / coverage output
[Tt]est[Rr]esults/

# IDE / user-specific
.vs/
*.user
*.suo

# Secrets — never commit (the leaked DB password was moved to user-secrets/env)
**/appsettings.*.json
!**/appsettings.example.json
**/secrets.json
*.env

# TLS material — only the PUBLIC ca.crt may be distributed to clients; keys/server cert stay on the broker
**/certs/*.key
**/certs/*.pem
**/certs/server.crt
**/*.pfx

# Mosquitto password file (PBKDF2 hash) — never commit; rotate via mosquitto_passwd
**/broker-setup/passwd
