# Template for Smart_Home environment variables.
# Copy this file to `.env` and fill in real values. `.env` is gitignored; this template is committed.
# Loaded by EnvFileLoader at startup; real process env vars override these values.

# PostgreSQL connection string used by AppDbContext (Npgsql).
# Takes precedence over appsettings.json -> ConnectionStrings:DefaultConnection.
SMART_HOME_CONNECTION_STRING=Host=localhost;Port=5432;Database=Smart_Home_db;Username=postgres;Password=__YOUR_PASSWORD__

# MQTT broker credentials (optional — leave blank for an anonymous broker).
MQTT_USERNAME=
MQTT_PASSWORD=
