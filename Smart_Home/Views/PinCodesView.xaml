<UserControl x:Class="Smart_Home.View.PinCodesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="800">
    <Grid Background="Transparent">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource BgMedium}" Margin="10" CornerRadius="8">
            <Grid Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Danh sách Mã PIN" Foreground="White" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,15"/>

                <DataGrid Grid.Row="1" ItemsSource="{Binding PinsList}" SelectedItem="{Binding SelectedPin, Mode=TwoWay}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="Auto"/>
                        <DataGridTextColumn Header="Chủ mã PIN" Binding="{Binding User.FullName}" Width="*"/>
                        <DataGridTextColumn Header="Số lần thử sai" Binding="{Binding FailedAttempts}" Width="Auto"/>
                        <DataGridCheckBoxColumn Header="Hoạt động" Binding="{Binding IsActive}" Width="Auto"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Column="1" Background="{StaticResource BgMedium}" Margin="0,10,10,10" CornerRadius="8">
            <StackPanel Margin="25">
                <TextBlock Text="Thông tin Mã PIN" Foreground="White" FontSize="22" FontWeight="SemiBold" Margin="0,0,0,25"/>
                <TextBlock Text="Chủ mã PIN (Người dùng)" Foreground="#CCCCCC" FontSize="15"/>
                <ComboBox ItemsSource="{Binding UsersList}" SelectedItem="{Binding SelectedUser, Mode=TwoWay}" DisplayMemberPath="FullName"/>
                <TextBlock Text="Mã PIN (Nhập mới)" Foreground="#CCCCCC" FontSize="15"/>
                <TextBox Text="{Binding PinInput, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBlock Text="Bỏ trống ô này nếu bạn không muốn đổi mã PIN cũ" Foreground="#999999" FontSize="13" Margin="0,-15,0,20" FontStyle="Italic"/>
                <CheckBox Content="Đang hoạt động" IsChecked="{Binding IsActive}" Foreground="White" Margin="0,5,0,25" FontSize="15"/>

                <Grid Margin="0,15,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Row="0" Grid.Column="0" Content="Thêm mới" Command="{Binding AddPinCommand}" Style="{StaticResource ActionBtn}" Margin="0,0,5,10"/>
                    <Button Grid.Row="0" Grid.Column="1" Content="Cập nhật" Command="{Binding UpdatePinCommand}" Style="{StaticResource ActionBtn}" Margin="5,0,0,10"/>
                    <Button Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Content="Khóa PIN" Command="{Binding DeletePinCommand}" Style="{StaticResource DangerBtn}"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
