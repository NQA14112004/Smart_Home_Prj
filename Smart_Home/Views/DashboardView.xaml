<UserControl x:Class="Smart_Home.View.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1000">
    <Grid Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Tổng quan Dashboard" Foreground="White" FontSize="28" FontWeight="SemiBold" Margin="10,10,0,20"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <WrapPanel Margin="0,0,0,20">
                <Border Style="{StaticResource CardStyle}" Width="300" Height="180">
                    <StackPanel Margin="15">
                        <TextBlock Text="Trạng thái Node &amp; Broker" Foreground="#AAAAAA" FontSize="16" Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,5">
                            <Ellipse Width="12" Height="12" Fill="{Binding DoorNodeOnline, Converter={StaticResource BoolToColorConverter}, FallbackValue=LimeGreen}" Margin="0,0,10,0"/>
                            <TextBlock Text="ESP32 Cửa:" Foreground="White" FontSize="16" Width="100"/>
                            <TextBlock Text="{Binding DoorNodeOnline}" Foreground="White" FontSize="16"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,5">
                            <Ellipse Width="12" Height="12" Fill="{Binding HomeNodeOnline, Converter={StaticResource BoolToColorConverter}, FallbackValue=LimeGreen}" Margin="0,0,10,0"/>
                            <TextBlock Text="ESP32 Nhà:" Foreground="White" FontSize="16" Width="100"/>
                            <TextBlock Text="{Binding HomeNodeOnline}" Foreground="White" FontSize="16"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Ellipse Width="12" Height="12" Fill="{Binding IsMqttConnected, Converter={StaticResource BoolToColorConverter}, FallbackValue=Gray}" Margin="0,0,10,0"/>
                            <TextBlock Text="MQTT Broker:" Foreground="White" FontSize="16" Width="100"/>
                            <TextBlock Text="{Binding IsMqttConnected}" Foreground="White" FontSize="16"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}" Width="300" Height="150">
                    <StackPanel Margin="15">
                        <TextBlock Text="Cửa &amp; Khóa" Foreground="#AAAAAA" FontSize="16" Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,5">
                            <TextBlock Text="Cửa:" Foreground="White" FontSize="18" Width="80"/>
                            <TextBlock Text="{Binding DoorStatus}" Foreground="#FFD700" FontSize="18" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <TextBlock Text="Khóa:" Foreground="White" FontSize="18" Width="80"/>
                            <TextBlock Text="{Binding LockStatus}" Foreground="#FF6347" FontSize="18" FontWeight="Bold"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}" Width="300" Height="150">
                    <StackPanel Margin="15">
                        <TextBlock Text="Cảnh báo mới nhất" Foreground="#AAAAAA" FontSize="16" Margin="0,0,0,10"/>
                        <TextBlock Text="{Binding LatestAlertLevel}" Foreground="Orange" FontSize="18" FontWeight="Bold" Margin="0,10,0,5"/>
                        <TextBlock Text="{Binding LatestAlertMessage}" Foreground="White" FontSize="16" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}" Width="465" Height="250">
                    <Grid Margin="15">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Nhiệt độ" Foreground="#AAAAAA" FontSize="16"/>
                            <TextBlock Text="{Binding Temperature, StringFormat={}{0:F1} °C}" Foreground="White" FontSize="24" FontWeight="Bold" Margin="20,0,0,0"/>
                        </StackPanel>
                        <lvc:CartesianChart Grid.Row="1" Series="{Binding TemperatureSeries}" Margin="0,10,0,0"/>
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardStyle}" Width="465" Height="250">
                    <Grid Margin="15">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Độ ẩm" Foreground="#AAAAAA" FontSize="16"/>
                            <TextBlock Text="{Binding Humidity, StringFormat={}{0:F1}%}" Foreground="White" FontSize="24" FontWeight="Bold" Margin="20,0,0,0"/>
                        </StackPanel>
                        <lvc:CartesianChart Grid.Row="1" Series="{Binding HumiditySeries}" Margin="0,10,0,0"/>
                    </Grid>
                </Border>

                <Border Style="{StaticResource CardStyle}" Width="300" Height="200">
                    <StackPanel Margin="15">
                        <TextBlock Text="Môi trường" Foreground="#AAAAAA" FontSize="16" Margin="0,0,0,15"/>
                        <StackPanel Orientation="Horizontal" Margin="0,5">
                            <TextBlock Text="Khí Gas:" Foreground="White" FontSize="16" Width="100"/>
                            <TextBlock Text="{Binding GasValue}" Foreground="LightCoral" FontSize="16" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,15,0,5">
                            <TextBlock Text="Ánh sáng:" Foreground="White" FontSize="16" Width="100"/>
                            <TextBlock Text="{Binding LightValue}" Foreground="LightSkyBlue" FontSize="16" FontWeight="Bold"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}" Width="630" Height="200">
                    <StackPanel Margin="15">
                        <TextBlock Text="Thiết bị (Truy cập nhanh)" Foreground="#AAAAAA" FontSize="16" Margin="0,0,0,15"/>
                        <WrapPanel>
                            <CheckBox Content="Đèn phòng khách" IsChecked="{Binding LivingRoomLightOn}" IsEnabled="False" Foreground="White" Margin="0,0,20,10"/>
                            <CheckBox Content="Đèn phòng ngủ 1" IsChecked="{Binding Bedroom1LightOn}" IsEnabled="False" Foreground="White" Margin="0,0,20,10"/>
                            <CheckBox Content="Đèn phòng ngủ 2" IsChecked="{Binding Bedroom2LightOn}" IsEnabled="False" Foreground="White" Margin="0,0,20,10"/>
                            <CheckBox Content="Quạt thông gió" IsChecked="{Binding FanOn}" IsEnabled="False" Foreground="White" Margin="0,0,20,10"/>
                            <CheckBox Content="Đèn LED ngoài trời" IsChecked="{Binding OutdoorLedOn}" IsEnabled="False" Foreground="White" Margin="0,0,20,10"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>
            </WrapPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
