<UserControl x:Class="Smart_Home.View.AlertsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="1000">
    <Grid Background="Transparent">
        <Border Background="{StaticResource BgMedium}" Margin="10" CornerRadius="8">
            <Grid Margin="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Lịch Sử Cảnh Báo (Alerts)" Foreground="White" FontSize="24" FontWeight="SemiBold" Margin="0,0,0,20"/>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,25">
                    <TextBlock Text="Từ ngày:" Foreground="White" FontSize="15" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <DatePicker SelectedDate="{Binding StartDate}" Width="150" Height="30" FontSize="14" Margin="0,0,20,0"/>
                    <TextBlock Text="Đến ngày:" Foreground="White" FontSize="15" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <DatePicker SelectedDate="{Binding EndDate}" Width="150" Height="30" FontSize="14" Margin="0,0,20,0"/>
                    <Button Content="Lọc dữ liệu" Command="{Binding LoadDataCommand}" Style="{StaticResource ActionBtn}"/>
                </StackPanel>

                <DataGrid Grid.Row="2" ItemsSource="{Binding AlertsList}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Thời gian (UTC)" Binding="{Binding CreatedAt, StringFormat={}{0:dd/MM/yyyy HH:mm:ss}}" Width="Auto"/>
                        <DataGridTextColumn Header="Mức độ" Binding="{Binding Level}" Width="Auto"/>
                        <DataGridTextColumn Header="Nội dung cảnh báo" Binding="{Binding Message}" Width="*"/>
                        <DataGridTextColumn Header="Nút cảm biến" Binding="{Binding Node.NodeCode}" Width="Auto"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
